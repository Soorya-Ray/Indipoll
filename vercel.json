{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/refresh-stations",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/retrain-model",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
